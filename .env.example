# Copy to .env and adjust.

# DEMO mode: registrar writes are mocked and verify succeeds 8s after install.
# Detection (/api/detect) is always real. Set false for live registrar writes.
DEMO=true

# Port the Node server listens on (nginx proxies to this).
PORT=4180

# Public base URL embedded in the TXT records and served from /manifests.
# Set this to YOUR manifest host (e.g. a subdomain proxied to /manifests).
MANIFEST_BASE=https://manifests.example.com
